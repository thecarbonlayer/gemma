# Copy to .env and adjust. The agent reads these via the model/ provider seam.
# Local dev / acceptance: an LM Studio server exposing an OpenAI-compatible API.
LLM_BASE_URL=http://192.168.189.144:1234/v1
LLM_MODEL=google/gemma-4-26b-a4b
LLM_API_KEY=lm-studio

# Any OpenAI-compatible endpoint works — point these at OpenRouter, Ollama, etc.:
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemma-3-27b-it
# LLM_API_KEY=sk-or-...
